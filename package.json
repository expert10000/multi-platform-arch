{
  "name": "dzone-shared-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Runtime-independent enterprise application platform starter.",
  "scripts": {
    "start": "node apps/backends/node/src/index.js",
    "start:backend:node": "node apps/backends/node/src/index.js",
    "start:backend:python": "python apps/backends/python/app.py",
    "start:backend:spring": "mvn -f apps/backends/spring/pom.xml spring-boot:run",
    "start:backend:aspnet": "dotnet run --project apps/backends/aspnet-core/DzoneAspNetCoreBackend.csproj --urls http://127.0.0.1:3300",
    "start:host:electron": "npm --prefix apps/hosts/electron start",
    "start:host:dotnet-desktop": "dotnet run --project apps/hosts/dotnet-desktop/DzoneDotnetDesktopHost.csproj --no-launch-profile",
    "start:host:maui": "dotnet run --project apps/hosts/maui/DzoneMauiHost/DzoneMauiHost.csproj -f net10.0-windows10.0.19041.0 --no-launch-profile",
    "check:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-local-prerequisites.ps1",
    "setup:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "check:tool:python": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-python-tooling.ps1 -CheckOnly",
    "setup:tool:python": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-python-tooling.ps1",
    "check:tool:dotnet": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-dotnet-tooling.ps1 -CheckOnly",
    "setup:tool:dotnet": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-dotnet-tooling.ps1",
    "check:host:electron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-electron-deps.ps1 -CheckOnly",
    "setup:host:electron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-electron-deps.ps1",
    "check:host:maui": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-maui-workload.ps1 -CheckOnly",
    "setup:host:maui": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-maui-workload.ps1",
    "test": "node --test tests/*.test.js",
    "check": "npm test"
  },
  "engines": {
    "node": ">=20"
  }
}
